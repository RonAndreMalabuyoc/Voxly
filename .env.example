DATABASE_PATH=backend/data/voxly.db
DICTIONARY_PATH=backend/data/personal_dictionary.md
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Cross-browser audio transcription.
# Use "mock" for no-key development, or "deepgram" for real speech-to-text.
STT_PROVIDER=mock
DEEPGRAM_API_KEY=
DEEPGRAM_BASE_URL=https://api.deepgram.com/v1/listen
DEEPGRAM_MODEL=nova-3
DEEPGRAM_LANGUAGE=en
DEEPGRAM_TIMEOUT_SECONDS=180

# Local AI correction.
# Use "mock" for deterministic demo rules, or "ollama" for local model correction.
CORRECTION_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=gemma3:1b
OLLAMA_TIMEOUT_SECONDS=120
