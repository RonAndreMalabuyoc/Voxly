DATABASE_PATH=backend/data/voxly.db
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Cross-browser audio transcription.
# Use "mock" for no-key development, or "deepgram" for real speech-to-text.
STT_PROVIDER=mock
DEEPGRAM_API_KEY=
DEEPGRAM_BASE_URL=https://api.deepgram.com/v1/listen
DEEPGRAM_MODEL=nova-3
DEEPGRAM_KEYTERMS=Wispr Flow,ROCm,Fireworks AI,Gemma,AMD Developer Cloud,Codex,FastAPI,SQLite
